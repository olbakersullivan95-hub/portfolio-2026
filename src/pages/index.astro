---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/obs-yellow.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Olivia Baker-Sullivan — Product & UX Designer" />
  <title>Olivia Baker-Sullivan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:opsz,wght@6..24,300;6..24,400&display=swap" rel="stylesheet" />
  <style>
    @font-face {
      font-family: "Sunliner Revival";
      src: url("/fonts/SunlinerRevival.ttf") format("truetype");
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --cream: #E9E3D7;
      --ink: #1a1a1a;
      --ink-mid: #555555;
      --ink-light: #636363;
      --border: rgba(26, 26, 26, 0.12);
    }

    html, body {
      height: 100%;
      background: var(--cream);
      color: var(--ink);
      font-family: 'Noto Sans', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 3rem 2rem;
      position: relative;
      overflow: hidden;
    }

    @media (max-width: 800px) {
      body { padding: 3rem 20px; }
    }

    /* ── Monogram ── */
    .obs-monogram {
      align-self: center;
      margin-bottom: 1.5rem;
      opacity: 0;
      transform: translateY(140px) scale(4.1);
      animation:
        monogram-enter  0.3s ease 0s forwards,
        monogram-shrink 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
      pointer-events: none;
    }

    .obs-monogram img {
      width: 39px;
      display: block;
    }

    @keyframes monogram-enter {
      from { opacity: 0; transform: translateY(140px) scale(4.1); }
      to   { opacity: 1; transform: translateY(140px) scale(4.1); }
    }

    @keyframes monogram-shrink {
      from { opacity: 1; transform: translateY(140px) scale(4.1); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Nav ── */
    .obs-nav {
      width: 100%;
      max-width: 420px;
      display: flex;
      flex-direction: column;
    }

    .obs-row {
      display: flex;
      align-items: flex-end;
      gap: 12px;
      padding: 1.8rem 0 1.4rem;
      border-top: 0.5px solid var(--border);
      cursor: pointer;
      text-decoration: none;
      color: var(--ink);
      transition: all 0.15s ease;
      opacity: 0;
      transform: translateY(10px);
    }

    .obs-row:last-child {
      border-bottom: 0.5px solid var(--border);
    }

    .obs-row.r1 { animation: row-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.4s forwards; }
    .obs-row.r2 { animation: row-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 1.7s forwards; }
    .obs-row.r3 { animation: row-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 2.0s forwards; }

    @keyframes row-in {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .obs-slug {
      font-family: 'Noto Sans', sans-serif;
      font-size: 11px;
      font-weight: 300;
      color: var(--ink-light);
      letter-spacing: 0.05em;
      min-width: 72px;
      flex-shrink: 0;
      transition: color 0.15s ease;
    }

    .obs-label {
      font-family: "Sunliner Revival", serif;
      font-size: 36px;
      line-height: 0.55;
      flex: 1;
      transition: transform 0.15s ease;
    }

    .obs-tag {
      font-family: 'Noto Sans', sans-serif;
      font-size: 10px;
      font-weight: 300;
      color: var(--ink-light);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      transition: color 0.15s ease;
    }

    .obs-row:hover .obs-slug { color: var(--ink-mid); }
    .obs-row:hover .obs-label { transform: translateX(4px); font-style: italic; }
    .obs-row:hover .obs-tag  { color: var(--ink-mid); }

    .obs-row.default .obs-label { font-style: italic; }
    .obs-row.default .obs-slug  { color: var(--ink-mid); }

    /* ── Redirect indicator ── */
    .obs-redirect {
      margin-top: 1.25rem;
      font-family: 'Noto Sans', sans-serif;
      font-size: 13px;
      letter-spacing: 0.12em;
      color: var(--ink-light);
      text-transform: uppercase;
      opacity: 0;
      animation: row-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 2.7s forwards;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .obs-bar {
      width: 100px;
      height: 0.5px;
      background: var(--border);
      position: relative;
      overflow: hidden;
    }

    .obs-bar-fill {
      position: absolute;
      top: 0; left: 0;
      height: 100%;
      width: 0%;
      background: var(--ink-light);
      animation: bar-fill 7s linear 3.5s forwards;
    }

    @keyframes bar-fill {
      from { width: 0%; }
      to   { width: 100%; }
    }
  </style>
</head>
<body>

  <nav class="obs-nav">
    <div class="obs-monogram"><img src="/obs-logo-hero.svg" alt="OBS" /></div>
    <a class="obs-row r1 default" href="/work">
      <span class="obs-slug">/portfolio</span>
      <span class="obs-label">Portfolio</span>
      <span class="obs-tag">UX · Brand · Product</span>
    </a>
    <a class="obs-row r2" href="/archive">
      <span class="obs-slug">/archive</span>
      <span class="obs-label">Archive</span>
      <span class="obs-tag">Process · Past work</span>
    </a>
    <a class="obs-row r3" href="/shop">
      <span class="obs-slug">/shop</span>
      <span class="obs-label">Shop</span>
      <span class="obs-tag">Prints · Objects</span>
    </a>

    <div class="obs-redirect">
      <span>Continuing to portfolio</span>
      <div class="obs-bar"><div class="obs-bar-fill"></div></div>
    </div>
  </nav>

  <script>
    const REDIRECT_URL = '/work';
    const REDIRECT_DELAY = 14000;

    const timer = setTimeout(() => {
      window.location.href = REDIRECT_URL;
    }, REDIRECT_DELAY);

    document.querySelectorAll('.obs-row').forEach(row => {
      row.addEventListener('click', () => clearTimeout(timer));
    });
  </script>

</body>
</html>
