---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const otherProjects = allProjects.filter(p => p.slug !== 'square-industry');

const opener = "A desert looks infinite until someone maps it. Cyrous mapped it, and set me to the task of crossing it.";

const title = "Square Industry Page Redesign";
const employer = "Block / Square";
const period = "2025";
const tags = ["Systems Thinking", "Production", "QA", "Stakeholder Mgmt", "Web"];
const stats = [
  { value: "10x",  label: "YoY Pageviews" },
  { value: "230x", label: "YoY Signups" },
  { value: "310x", label: "BoF NPA Increase" },
];

const introOriginal = `Square's industry landing page was one of many pages in a sprawling public web ecosystem of 17,000+ managed pages. The redesign was part of a broader initiative to modernize Square's public web presence, a multi-phase effort involving designers, developers, product marketing managers, and international stakeholders.

My role was to make sure that whatever was designed actually shipped, accurately, accessibly, and on time, and that every person touching the project had what they needed to do their part.`;

const p1 = `Square's industry landing page lived inside a sprawling public web ecosystem that most people didn't know existed and nobody had fully mapped. The redesign was part of a broader initiative to modernize Square's public web presence, a multi-phase effort involving designers, developers, product marketing managers, and international stakeholders who didn't always know each other's names. The role wasn't to concept the visual direction. The work was to make sure that whatever was designed actually shipped, accurately, accessibly, and on time.`;

const p2 = `Production work at this scale is less about making things and more about holding things together: understanding which decision affects which downstream dependency, which stakeholder needs to sign off before the developer can build, which QA round needs to happen before the next one can begin. That full chain was mine, production build and QA across all page variants and device sizes, cross-functional alignment between design, development, and marketing, and a constant, quiet effort to surface and resolve blockers before they became anyone else's problem.`;

const p3 = `What made this project land wasn't a single deliverable. It was the connective tissue, the communication that kept everyone moving in the same direction, the QA that caught the things that would have shipped wrong, the presence that meant every person on the project always knew where things stood. That kind of work doesn't always show up in the credits. It shows up in the results.`;

const quote = `"Kudos to Jess, Laura, and Olivia for reimagining square.com/industry. Over the past 6 months YoY, the page has seen a 10x in pageviews, a 230x in signups, and a 310x increase in BoF NPA. Amazing results!"`;
const attribution = "Cyrous Bortey, Block";
const liveUrl = "https://squareup.com/us/es/industry";
---

<Base title="Sandbox, Square Industry" activePage="portfolio">

  <!-- Opener overlay -->
  <div class="sb-overlay" id="sb-overlay" aria-hidden="true">
    <div class="sb-opener-wrap">
      <p class="sb-opener-text" id="sb-opener-text" data-opener={opener}></p>
      <button class="sb-skip" id="sb-skip">Skip →</button>
    </div>
  </div>

  <!-- Case study content -->
  <div class="sb-content" id="sb-content">
    <div class="case-study-wrap">
      <a href="/work" class="back-btn">← Portfolio</a>

    <!-- ── Section 1: original layout, scanner moment ── -->
    <div class="case-study-grid">
      <div class="cs-row">
        <div class="cs-text cs-text--intro">
          <h1 class="cs-title">{title}</h1>
          <p class="cs-meta">{employer} · {period}</p>
          <ul class="cs-stats">
            {stats.map(s => <li><span class="stat-value">{s.value}</span><span class="stat-label">{s.label}</span></li>)}
          </ul>
          <ul class="cs-tags">{tags.map(t => <li>{t}</li>)}</ul>
          <div class="cs-intro">
            {introOriginal.trim().split(/\n\n+/).map(p => <p>{p}</p>)}
          </div>
        </div>
        <div class="cs-image cs-image--1">
          <!-- landscape "in the wild" hero -->
          <img src="/images/projects/block-1/img-1.webp" alt="Square industry, in the wild" loading="eager" fetchpriority="high" />
        </div>
      </div>
    </div>

    <!-- ── Section 2: new asymmetric grid ── -->
    <div class="cs-body-grid">

      <!-- Row 1: [empty][img: 2-3][text: 4-5][empty] -->
      <div class="csg-img1">
        <img src="/images/sandbox/sq-industry-2.png" alt="Square industry page" loading="lazy" />
      </div>
      <div class="csg-text1">
        <p>{p1}</p>
      </div>

      <!-- Row 2: [text: 1-2][img: 3-6] -->
      <div class="csg-text2">
        <p>{p2}</p>
      </div>
      <div class="csg-img2">
        <img src="/images/sandbox/sq-industry-3.png" alt="Square industry merchants" loading="lazy" />
      </div>

      <!-- Row 3: [empty][img: 2-3][text: 4-5][empty] -->
      <div class="csg-img3">
        <img src="/images/sandbox/sq-industry-4.png" alt="Square industry detail" loading="lazy" />
      </div>
      <div class="csg-text3">
        <p>{p3}</p>
      </div>

      <!-- Row 4: [empty][quote: 2-6] -->
      <div class="csg-quote">
        <blockquote>
          <p>{quote}</p>
          <cite>— {attribution}</cite>
        </blockquote>
      </div>

      <!-- Row 5: [empty][url: 2-3] -->
      <div class="csg-url">
        <a href={liveUrl} target="_blank" rel="noopener" class="cs-live-link">See the work live →</a>
      </div>

    </div>
    </div><!-- /.case-study-wrap -->
  </div><!-- /.sb-content -->

  <!-- Carousel -->
  <div class="carousel" id="carousel">
    <div class="carousel__track-wrap">
      <div class="carousel__track" id="carousel-track">
        {otherProjects.map((project) => (
          <a href={`/work/${project.slug}`} class="carousel__item">
            <img src={project.data.coverImage} alt={project.data.title} loading="lazy" />
            <span>{project.data.title}</span>
          </a>
        ))}
      </div>
    </div>
    <div class="carousel__arrows">
      <button class="carousel__arrow carousel__arrow--prev" aria-label="Previous" id="carousel-prev">←</button>
      <button class="carousel__arrow carousel__arrow--next" aria-label="Next" id="carousel-next">→</button>
    </div>
  </div>

</Base>

<style>
  /* ── Overlay ── */
  .sb-overlay {
    position: fixed;
    inset: 0;
    background: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem var(--margin);
    z-index: 100;
    transition: transform 0.7s cubic-bezier(0.76, 0, 0.24, 1);
  }
  .sb-overlay.is-leaving {
    transform: translateY(-100%);
    pointer-events: none;
  }
  .sb-opener-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 600px;
  }
  .sb-opener-text {
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.55;
    color: var(--ink);
  }
  .sb-opener-text .sb-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(6px);
    animation: word-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }
  .sb-skip {
    background: none;
    border: none;
    font-size: var(--text-xs);
    color: var(--ink-mid);
    cursor: pointer;
    letter-spacing: 0.05em;
    padding: 16px 0 0;
    transition: color 0.15s;
  }
  .sb-skip:hover { color: var(--ink); }

  /* ── Content ── */
  .sb-content {
    opacity: 0;
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .sb-content.is-visible { opacity: 1; }

  .sb-content .case-study-wrap { padding-top: 3rem; }

  /* ── New asymmetric grid ── */
  .cs-body-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    column-gap: var(--gutter);
    row-gap: 100px;
    padding: 80px 0 6rem;
    align-items: start;
  }

  /* Row 1 */
  .csg-img1  { grid-column: 2 / 4; grid-row: 1; }
  .csg-text1 { grid-column: 4 / 6; grid-row: 1; align-self: start; }

  /* Row 2 */
  .csg-text2 { grid-column: 1 / 3; grid-row: 2; align-self: start; }
  .csg-img2  { grid-column: 3 / 7; grid-row: 2; }

  /* Row 3 */
  .csg-img3  { grid-column: 2 / 4; grid-row: 3; }
  .csg-text3 { grid-column: 4 / 6; grid-row: 3; align-self: start; }

  /* Row 4 */
  .csg-quote { grid-column: 2 / 6; grid-row: 4; }

  /* Row 5 */
  .csg-url   { grid-column: 2 / 4; grid-row: 5; }

  .cs-body-grid img { width: 100%; display: block; }

  .csg-text1 p,
  .csg-text2 p,
  .csg-text3 p {
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--ink);
  }

  .csg-quote blockquote {
    border-left: 0.5px solid var(--border);
    padding-left: 1.5rem;
  }
  .csg-quote blockquote p {
    font-family: "Sunliner Revival", serif;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  .csg-quote blockquote cite {
    font-size: var(--text-xs);
    color: var(--ink-mid);
    font-style: normal;
  }
</style>

<script>
  const overlay  = document.getElementById('sb-overlay')!;
  const openerEl = document.getElementById('sb-opener-text')!;
  const content  = document.getElementById('sb-content')!;
  const skipBtn  = document.getElementById('sb-skip')!;

  const WORD_STAGGER = 0.08;
  const HOLD_MS      = 1200;

  function reveal() {
    const words = (openerEl.dataset.opener ?? '').split(' ');
    const totalRevealMs = words.length * WORD_STAGGER * 1000 + 400;
    openerEl.innerHTML = words
      .map((w, i) => `<span class="sb-word" style="animation-delay:${(i * WORD_STAGGER).toFixed(2)}s">${w}</span>`)
      .join(' ');
    setTimeout(dismiss, totalRevealMs + HOLD_MS);
  }

  function dismiss() {
    overlay.classList.add('is-leaving');
    setTimeout(() => {
      overlay.remove();
      content.classList.add('is-visible');
    }, 700);
  }

  skipBtn.addEventListener('click', dismiss);
  setTimeout(reveal, 200);

  // Carousel
  const track = document.getElementById('carousel-track') as HTMLElement;
  const prev  = document.getElementById('carousel-prev');
  const next  = document.getElementById('carousel-next');
  let offset  = 0;

  function getItemWidth() {
    const item = track?.querySelector('.carousel__item') as HTMLElement;
    if (!item) return 0;
    return item.offsetWidth + (parseInt(getComputedStyle(track).gap) || 20);
  }

  prev?.addEventListener('click', () => {
    offset = Math.max(0, offset - getItemWidth());
    track.style.transform = `translateX(-${offset}px)`;
  });
  next?.addEventListener('click', () => {
    const max = track.scrollWidth - track.parentElement!.offsetWidth;
    offset = Math.min(max, offset + getItemWidth());
    track.style.transform = `translateX(-${offset}px)`;
  });
</script>
