---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => p.slug !== 'everbloom')
  .sort((a, b) => a.data.order - b.data.order);

const companyBySlug: Record<string, string> = {
  'square-industry': 'Block',
  'vpos': 'Block',
  'x2c': 'Block',
  'square-50': 'Block',
  'ebay-design-system': 'eBay',
  'small-business-saturday': 'eBay',
  'ebay-socials': 'eBay',
  'bodies-and-sound': 'Bodies and Sound',
  'nscad-es-brand': 'NSCAD',
  'nscad-es-web': 'NSCAD',
  'wheelhouse': 'Wheelhouse',
  'ttc-redesign': 'TTC',
  'everbloom': 'Everbloom',
};
---

<Base title="Portfolio" activePage="portfolio">
  <div class="headliner">
    <p class="headliner__left">Olivia Baker-Sullivan — Product &amp; UX Designer<br>I design web and product experiences that ship across acquisition, onboarding, and global launches.</p>
    <p class="headliner__right">Block, DEPT, NSCAD</p>
  </div>
  <div class="grid grid--portfolio" id="portfolio-grid">
    {projects.map((project) => (
      <a
        href={`/work/${project.slug}`}
        class="grid__item"
        data-categories={JSON.stringify(project.data.categories)}
      >
        <img
          src={project.data.coverImage}
          alt={project.data.title}
          loading="lazy"
          decoding="async"
        />
        <span class="grid__item-company">/{companyBySlug[project.slug] ?? ''}</span>
        <span class="grid__item-label">/{project.slug}</span>
      </a>
    ))}
  </div>
</Base>

<script>
  const filterTags = document.querySelectorAll<HTMLElement>('.nav-filters__tag');
  const gridItems = document.querySelectorAll<HTMLElement>('#portfolio-grid .grid__item');
  const activeFilters = new Set<string>();

  filterTags.forEach((tag) => {
    tag.addEventListener('click', () => {
      const filter = tag.dataset.filter ?? '';
      if (activeFilters.has(filter)) {
        activeFilters.delete(filter);
        tag.classList.remove('is-active');
      } else {
        activeFilters.add(filter);
        tag.classList.add('is-active');
      }
      applyFilters();
    });
  });

  function applyFilters() {
    gridItems.forEach((item) => {
      if (activeFilters.size === 0) {
        item.style.display = '';
        return;
      }
      const cats: string[] = JSON.parse(item.dataset.categories ?? '[]');
      const match = cats.some((c) => activeFilters.has(c));
      item.style.display = match ? '' : 'none';
    });
  }
</script>
