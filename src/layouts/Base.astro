---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: 'archive' | 'about' | 'portfolio' | 'shop';
}
const {
  title,
  description = 'Olivia Baker-Sullivan — Designer',
  activePage,
} = Astro.props;

const filters = ['UX', 'Brand', 'Product', 'Photography', 'Painting', 'Video', 'Animation', 'Writing'];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/obs-yellow.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Olivia Baker-Sullivan</title>
    <meta property="og:title" content={`${title} — Olivia Baker-Sullivan`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://oliviabakersullivan.ca/social-share.jpg" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://oliviabakersullivan.ca/social-share.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,opsz,wdth,wght@0,6..24,62.5..100,100..900;1,6..24,62.5..100,100..900&display=swap" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__left">
        <a href="/"><img src="/obs-logo.svg" alt="OBS" class="logo" width="39" height="18" /></a>
        <nav class="nav-main" aria-label="Main navigation">
          <a href="/archive" class:list={['nav-main__link', { 'is-active': activePage === 'archive' }]}>Archive</a>
          <a href="/about" class:list={['nav-main__link', { 'is-active': activePage === 'about' }]}>About</a>
          <a href="/work" class:list={['nav-main__link', { 'is-active': activePage === 'portfolio' }]}>Portfolio</a>
          <a href="/shop" class:list={['nav-main__link', { 'is-active': activePage === 'shop' }]}>Shop</a>
        </nav>
      </div>
      {activePage === 'archive' && (
        <nav class="nav-filters" aria-label="Filter by category">
          {filters.map((tag) => (
            <span class="nav-filters__tag" data-filter={tag}>{tag}</span>
          ))}
        </nav>
      )}
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="site-footer">
      <img src="/obs-logo.svg" alt="OBS" width="39" height="18" />
      <ul class="site-footer__links">
        <li><a href="https://www.behance.net/olivialbaker" target="_blank" rel="noopener">Behance</a></li>
        <li><a href="https://www.linkedin.com/in/olivia-baker-sullivan/" target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href="https://www.instagram.com/obs_designs/" target="_blank" rel="noopener">Instagram</a></li>
        <li><a href="mailto:olbakersullivan95@gmail.com">Email</a></li>
      </ul>
    </footer>
  </body>
</html>

